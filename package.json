{
  "name": "nixpanel-server",
  "version": "1.0.0",
  "description": "NixPanel - Web-based Linux System Administration Panel",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "build:client": "cd client && npm install && npm run build",
    "install:all": "npm install && npm run build:client"
  },
  "dependencies": {
