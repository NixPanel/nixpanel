{
  "name": "nixpanel-server",
  "version": "1.0.1",
  "description": "NixPanel - Web-based Linux System Administration Panel",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "build:client": "cd client && npm install && npm run build",
    "install:all": "npm install && npm run build:client",
    "build:binary": "pkg server/index.js --targets node20-linux-x64 --output dist/nixpanel --compress GZip",
    "build:binary:all": "pkg server/index.js --targets node20-linux-x64,node20-macos-x64,node20-win-x64 --output dist/nixpanel --compress GZip",
    "release": "npm run build:binary && cp dist/nixpanel /tmp/nixpanel-release"
  },
  "pkg": {
    "scripts": "server/**/*.js",
    "assets": [
      "client/dist/**/*",
      "server/db/**/*",
      ".env.example",
      "node_modules/better-sqlite3/build/Release/better_sqlite3.node",
      "node_modules/better-sqlite3/build/Release/*.node"
    ],
    "targets": [
      "node20-linux-x64"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.4",
    "stripe": "^21.0.1",
    "systeminformation": "^5.22.11",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.11.5",
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
