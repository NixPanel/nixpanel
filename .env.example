# NixPanel Environment Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3001
NODE_ENV=production

# JWT Secret (generate with: openssl rand -hex 64)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT Token Expiry
JWT_EXPIRES_IN=24h

# Anthropic API Key for AI Assistant
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database path
DB_PATH=./nixpanel.db

# Admin credentials (used for initial setup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS origin (set to your domain in production)
CORS_ORIGIN=http://localhost:3000

# ─── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (find these in your Stripe dashboard → Products)
STRIPE_PRICE_SOLO_MONTHLY=price_...
STRIPE_PRICE_SOLO_ANNUAL=price_...
STRIPE_PRICE_HOST_MONTHLY=price_...
STRIPE_PRICE_HOST_ANNUAL=price_...
STRIPE_PRICE_AGENCY_MONTHLY=price_...
STRIPE_PRICE_AGENCY_ANNUAL=price_...

# Site URL (used in Stripe checkout success/cancel redirect)
SITE_URL=https://nixpanel.io

# ─── Email (nodemailer) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@nixpanel.io
SMTP_PASS=your_smtp_password
EMAIL_FROM=NixPanel <noreply@nixpanel.io>
EMAIL_SUPPORT=support@nixpanel.io
# Set EMAIL_DISABLED=true to suppress all emails (useful in dev/testing)
EMAIL_DISABLED=false

# ─── License Server ────────────────────────────────────────────────────────────
LICENSE_SERVER_HOST=license.nixpanel.io
LICENSE_SERVER_PORT=443
LICENSE_SERVER_HTTPS=true
LICENSE_SERVER_ADMIN_KEY=your_license_server_admin_key
